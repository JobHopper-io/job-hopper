        "parameters": {
          "jsCode": "const urls = new Set();\n\nif ($input.first().json.web.results) {\n  for (const result of $input.first().json.web.results) {\n    if (result.url) urls.add(result.url);\n  }\n}\n\nreturn Array.from(urls).map(url => ({\n  json: { url }\n}));"
        },
