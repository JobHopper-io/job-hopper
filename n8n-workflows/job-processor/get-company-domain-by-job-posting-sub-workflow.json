          "mode": "runOnceForEachItem",
          "jsCode": "const job_title = $('Start').item.json.job_title;\nconst company_name = $('Start').item.json.company_name;\nconst url = $json.url;\nconst error = $json.error;\n\nconsole.log(`Error: ${error}\\nURL: ${url}\\nCompany Name: ${company_name}\\njob_title:${job_title}`)\n\nreturn { json: {error: error, url: url, company_name: company_name, job_title: job_title} };"
        },
