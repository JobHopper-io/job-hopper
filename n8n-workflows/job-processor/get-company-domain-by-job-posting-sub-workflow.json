          "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor(let i = 0; i < $input.all().length; i++) {\n  $input.all()[i].json.url = $('Extract URLs from Search Result').itemMatching(i).json.url\n}\n\nreturn $input.all();"
        },
