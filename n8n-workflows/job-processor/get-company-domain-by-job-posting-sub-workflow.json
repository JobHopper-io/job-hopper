      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "// For n8n Code node – HTML from input or hardcoded\nconst html = $json.data;\n\nfunction stripHtmlToText(htmlString) {\n  if (!htmlString || typeof htmlString !== 'string') return '';\n\n  return htmlString\n    .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n    .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<head[^>]*>[\\s\\S]*?<\\/head>/gi, '')\n    .replace(/<noscript[^>]*>[\\s\\S]*?<\\/noscript>/gi, '')\n    .replace(/<svg[^>]*>[\\s\\S]*?<\\/svg>/gi, '')\n    .replace(/<!--[\\s\\S]*?-->/g, '')\n    .replace(/<\\s*\\/\\s*(p|div|li|tr|h[1-6]|section|article|header|footer|nav|main|ul|ol)[^>]*>/gi, ' ')\n    .replace(/<\\s*br\\s*\\/?>/gi, ' ')\n    .replace(/<[^>]+>/g, ' ')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/&quot;/g, '\"')\n    .replace(/&#8217;|&#39;/g, \"'\")\n    .replace(/&#8211;|&#45;/g, '-')\n    .replace(/&#038;/g, '&')\n    .replace(/&raquo;/g, '»')\n    .replace(/[\\s\\n\\r\\t]+/g, ' ')   // collapse all whitespace including \\n into single space\n    .trim();\n}\n\nconst text = stripHtmlToText(html);\n\nreturn { json: { text } };"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          160,
